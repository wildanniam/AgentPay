# Supabase Postgres.
# Use the pooled connection string for Vercel runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Optional direct Supabase database URL for local db:push or scripts.
# Prisma schema uses DATABASE_URL, so run db commands with DATABASE_URL="$DIRECT_URL" when needed.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

STELLAR_NETWORK="stellar:testnet"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
X402_FACILITATOR_URL="https://www.x402.org/facilitator"
PROVIDER_REQUEST_TIMEOUT_MS="12000"

# Optional. If set, provider registration requires this token.
TOOL_REGISTRATION_TOKEN="change-this-long-random-token"

# Demo provider wallet that receives x402 payments.
# Use a Stellar testnet public key with a USDC trustline.
DEMO_PROVIDER_STELLAR_PUBLIC_KEY="G..."

# External agent wallet that pays for local demo calls.
# Keep this only in .env.local, never commit it, and rotate it if it was shared.
AGENT_STELLAR_SECRET_KEY="S..."
